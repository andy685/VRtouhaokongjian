{
  "installCommand": "npm install --prefix admin-dashboard && npm install --prefix cashier-ui",
  "buildCommand": "npm run build",
  "outputDirectory": "admin-dashboard/dist",
  "rewrites": [
    {
      "source": "/cashier/(.*)",
      "destination": "/cashier/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
